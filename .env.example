# Copie para .env (não versionado).
#
# DATABASE_URL aqui aponta para localhost: é o que ferramentas rodadas no HOST
# usam (drizzle-kit generate/migrate/studio, importador) conectando pela porta
# publicada pelo container (DB_PORT). O serviço web dentro do Docker usa a URL
# com host "db" definida no compose.yaml.
# Publicamos em 5433 porque a 5432 costuma estar ocupada pelo Postgres local.
DATABASE_URL=postgres://crm:crm@localhost:5433/crm
DB_PORT=5433

# Porta do app no host (mude se a 3000 estiver ocupada por outro serviço)
WEB_PORT=3000

# Credenciais do container Postgres (lidas pelo compose.yaml)
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm
POSTGRES_DB=crm

# SMTP (envio de e-mail pelo CRM). Gmail: smtp.gmail.com:587 + senha de app
# (https://myaccount.google.com/apppasswords — exige verificação em 2 etapas).
# SMTP_FROM aceita "Nome <email@dominio.com>".
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Auth: em produção o cookie de sessão só trafega via HTTPS. Se for servir por
# http puro (ex.: IP na LAN, sem proxy TLS na frente), descomente:
# AUTH_COOKIE_SECURE=false
