# Copie para .env (não versionado).
#
# DATABASE_URL aqui aponta para localhost: é o que ferramentas rodadas no HOST
# usam (drizzle-kit generate/migrate/studio, importador) conectando pela porta
# publicada pelo container (DB_PORT). O serviço web dentro do Docker usa a URL
# com host "db" definida no compose.yaml.
# Publicamos em 5433 porque a 5432 costuma estar ocupada pelo Postgres local.
DATABASE_URL=postgres://crm:crm@localhost:5433/crm
DB_PORT=5433

# Credenciais do container Postgres (lidas pelo compose.yaml)
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm
POSTGRES_DB=crm
